{
    "openapi": "3.0.0",
    "info": {
        "title": "NextStep API",
        "description": "Job application tracking API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local development server"
        }
    ],
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "Token",
                "description": "Enter the token returned from /api/login"
            }
        },
        "schemas": {
            "SuccessResponse": {
                "type": "object",
                "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "type": "object" },
                    "message": { "type": "string" }
                }
            },
            "ErrorResponse": {
                "type": "object",
                "properties": {
                    "success": { "type": "boolean", "example": false },
                    "message": { "type": "string" },
                    "data": { "type": "object" }
                }
            },
            "User": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer", "example": 1 },
                    "name": { "type": "string", "example": "Jane Doe" },
                    "email": { "type": "string", "example": "jane@example.com" },
                    "created_at": { "type": "string", "format": "date-time" }
                }
            },
            "Cv": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer", "example": 1 },
                    "name": { "type": "string", "example": "Jane Doe" },
                    "email": { "type": "string", "example": "jane@example.com" },
                    "phone": { "type": "string", "example": "07700900000" },
                    "location": { "type": "string", "example": "London, UK" },
                    "links": { "type": "string", "example": "https://github.com/janedoe" },
                    "bio": { "type": "string", "example": "Software engineer with 5 years experience." },
                    "experience": { "type": "string" },
                    "education": { "type": "string" },
                    "skills": { "type": "string" }
                }
            },
            "Application": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer", "example": 1 },
                    "cv_id": { "type": "integer", "nullable": true, "example": 1 },
                    "company_name": { "type": "string", "example": "Acme Corp" },
                    "position": { "type": "string", "example": "Backend Developer" },
                    "location": { "type": "string", "nullable": true, "example": "London" },
                    "contact_email": { "type": "string", "nullable": true, "example": "hr@acme.com" },
                    "salary": { "type": "integer", "nullable": true, "example": 60000 },
                    "status": { "type": "string", "enum": ["applied", "interview", "offer", "rejected", "ghosted"] },
                    "job_type": { "type": "string", "nullable": true, "enum": ["full-time", "part-time", "internship", "contract"] },
                    "job_url": { "type": "string", "nullable": true },
                    "notes": { "type": "string", "nullable": true },
                    "applied_date": { "type": "string", "format": "date", "nullable": true }
                }
            },
            "Cover": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer", "example": 1 },
                    "application_id": { "type": "integer", "nullable": true },
                    "title": { "type": "string", "example": "Cover letter for Acme Corp" },
                    "content": { "type": "string", "example": "Dear Hiring Manager..." }
                }
            },
            "Event": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer", "example": 1 },
                    "application_id": { "type": "integer", "nullable": true },
                    "title": { "type": "string", "example": "Technical interview" },
                    "event_type": { "type": "string", "enum": ["interview", "reminder", "assessment", "call", "deadline"] },
                    "description": { "type": "string", "nullable": true },
                    "event_date": { "type": "string", "format": "date", "example": "2026-05-01" },
                    "is_all_day": { "type": "boolean", "example": false },
                    "event_time": { "type": "string", "example": "14:00", "nullable": true },
                    "location": { "type": "string", "nullable": true }
                }
            }
        }
    },
    "tags": [
        { "name": "Auth",          "description": "Authentication" },
        { "name": "CVs",           "description": "CV management" },
        { "name": "Applications",  "description": "Job application tracking" },
        { "name": "Cover Letters", "description": "Cover letter management" },
        { "name": "Events",        "description": "Calendar events and reminders" },
        { "name": "AI",            "description": "AI-powered CV assistant" }
    ],
    "paths": {
        "/api/register": {
            "post": {
                "tags": ["Auth"],
                "summary": "Register a new user",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["name", "email", "password"],
                                "properties": {
                                    "name":     { "type": "string", "example": "Jane Doe" },
                                    "email":    { "type": "string", "example": "jane@example.com" },
                                    "password": { "type": "string", "example": "password123", "minLength": 8 }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "User registered successfully" },
                    "422": { "description": "Validation error" }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": ["Auth"],
                "summary": "Login and get a bearer token",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["email", "password"],
                                "properties": {
                                    "email":    { "type": "string", "example": "jane@example.com" },
                                    "password": { "type": "string", "example": "password123" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Login successful — returns token and name" },
                    "401": { "description": "Invalid credentials" },
                    "422": { "description": "Validation error" }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": ["Auth"],
                "summary": "Logout — revokes the current token",
                "security": [{ "sanctum": [] }],
                "responses": {
                    "200": { "description": "Logged out successfully" },
                    "401": { "description": "Unauthenticated" }
                }
            }
        },
        "/api/user": {
            "get": {
                "tags": ["Auth"],
                "summary": "Get the authenticated user",
                "security": [{ "sanctum": [] }],
                "responses": {
                    "200": { "description": "User retrieved successfully" },
                    "401": { "description": "Unauthenticated" }
                }
            }
        },
        "/api/dashboard": {
            "get": {
                "tags": ["Applications"],
                "summary": "Dashboard summary (status counts, recent applications, upcoming events)",
                "security": [{ "sanctum": [] }],
                "responses": {
                    "200": {
                        "description": "Dashboard data retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean" },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "status_counts": {
                                                    "type": "object",
                                                    "properties": {
                                                        "applied":   { "type": "integer" },
                                                        "interview": { "type": "integer" },
                                                        "offer":     { "type": "integer" },
                                                        "rejected":  { "type": "integer" },
                                                        "ghosted":   { "type": "integer" }
                                                    }
                                                },
                                                "recent_applications": { "type": "array", "items": { "$ref": "#/components/schemas/Application" } },
                                                "upcoming_events":     { "type": "array", "items": { "$ref": "#/components/schemas/Event" } }
                                            }
                                        },
                                        "message": { "type": "string" }
                                    }
                                }
                            }
                        }
                    },
                    "401": { "description": "Unauthenticated" }
                }
            }
        },
        "/api/cvs": {
            "get": {
                "tags": ["CVs"],
                "summary": "List all CVs",
                "security": [{ "sanctum": [] }],
                "responses": {
                    "200": { "description": "CVs retrieved successfully" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "post": {
                "tags": ["CVs"],
                "summary": "Create a new CV",
                "security": [{ "sanctum": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["name", "email", "phone"],
                                "properties": {
                                    "name":       { "type": "string",  "example": "Jane Doe" },
                                    "email":      { "type": "string",  "example": "jane@example.com" },
                                    "phone":      { "type": "string",  "example": "07700900000" },
                                    "location":   { "type": "string",  "nullable": true },
                                    "links":      { "type": "string",  "nullable": true },
                                    "bio":        { "type": "string",  "nullable": true },
                                    "experience": { "type": "string",  "nullable": true },
                                    "education":  { "type": "string",  "nullable": true },
                                    "skills":     { "type": "string",  "nullable": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "CV created successfully" },
                    "401": { "description": "Unauthenticated" },
                    "422": { "description": "Validation error" }
                }
            }
        },
        "/api/cvs/{id}": {
            "get": {
                "tags": ["CVs"],
                "summary": "Get a specific CV",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "responses": {
                    "200": { "description": "CV retrieved successfully" },
                    "404": { "description": "CV not found" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "put": {
                "tags": ["CVs"],
                "summary": "Update a CV",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["name", "email", "phone"],
                                "properties": {
                                    "name":       { "type": "string" },
                                    "email":      { "type": "string" },
                                    "phone":      { "type": "string" },
                                    "location":   { "type": "string", "nullable": true },
                                    "links":      { "type": "string", "nullable": true },
                                    "bio":        { "type": "string", "nullable": true },
                                    "experience": { "type": "string", "nullable": true },
                                    "education":  { "type": "string", "nullable": true },
                                    "skills":     { "type": "string", "nullable": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "CV updated successfully" },
                    "404": { "description": "CV not found" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "delete": {
                "tags": ["CVs"],
                "summary": "Delete a CV",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "responses": {
                    "200": { "description": "CV deleted successfully" },
                    "404": { "description": "CV not found" },
                    "401": { "description": "Unauthenticated" }
                }
            }
        },
        "/api/cvs/{cv_id}/chat": {
            "post": {
                "tags": ["AI"],
                "summary": "Chat with the AI CV builder",
                "description": "Send a message to the AI assistant about a CV. Pass conversation_id to continue an existing conversation; omit it to start a new one. Optionally attach a document (PDF/DOC/DOCX/TXT) or image.",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "cv_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": ["message"],
                                "properties": {
                                    "message":         { "type": "string", "maxLength": 2000, "example": "Can you improve my professional summary?" },
                                    "conversation_id": { "type": "string", "nullable": true, "description": "Omit to start a new conversation" },
                                    "cv_file":         { "type": "string", "format": "binary", "nullable": true, "description": "PDF, DOC, DOCX, or TXT — max 5 MB" },
                                    "image":           { "type": "string", "format": "binary", "nullable": true, "description": "JPEG, PNG, GIF, or SVG — max 2 MB" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "AI response generated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean" },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "message":         { "type": "string" },
                                                "conversation_id": { "type": "string" }
                                            }
                                        },
                                        "message": { "type": "string" }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "description": "CV not found" },
                    "401": { "description": "Unauthenticated" }
                }
            }
        },
        "/api/applications": {
            "get": {
                "tags": ["Applications"],
                "summary": "List all job applications",
                "security": [{ "sanctum": [] }],
                "responses": {
                    "200": { "description": "Applications retrieved successfully" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "post": {
                "tags": ["Applications"],
                "summary": "Create a new job application",
                "security": [{ "sanctum": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["company_name", "position", "status"],
                                "properties": {
                                    "cv_id":          { "type": "integer", "nullable": true },
                                    "company_name":   { "type": "string",  "example": "Acme Corp" },
                                    "position":       { "type": "string",  "example": "Backend Developer" },
                                    "location":       { "type": "string",  "nullable": true },
                                    "contact_email":  { "type": "string",  "nullable": true },
                                    "salary":         { "type": "integer", "nullable": true, "example": 60000 },
                                    "status":         { "type": "string",  "enum": ["applied", "interview", "offer", "rejected", "ghosted"] },
                                    "job_type":       { "type": "string",  "nullable": true, "enum": ["full-time", "part-time", "internship", "contract"] },
                                    "job_url":        { "type": "string",  "nullable": true },
                                    "notes":          { "type": "string",  "nullable": true },
                                    "applied_date":   { "type": "string",  "format": "date", "nullable": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Application created successfully" },
                    "401": { "description": "Unauthenticated" },
                    "422": { "description": "Validation error" }
                }
            }
        },
        "/api/applications/{id}": {
            "get": {
                "tags": ["Applications"],
                "summary": "Get a specific job application",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "responses": {
                    "200": { "description": "Application retrieved successfully" },
                    "404": { "description": "Application not found" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "put": {
                "tags": ["Applications"],
                "summary": "Update a job application",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["company_name", "position", "status"],
                                "properties": {
                                    "cv_id":         { "type": "integer", "nullable": true },
                                    "company_name":  { "type": "string" },
                                    "position":      { "type": "string" },
                                    "location":      { "type": "string",  "nullable": true },
                                    "contact_email": { "type": "string",  "nullable": true },
                                    "salary":        { "type": "integer", "nullable": true },
                                    "status":        { "type": "string",  "enum": ["applied", "interview", "offer", "rejected", "ghosted"] },
                                    "job_type":      { "type": "string",  "nullable": true, "enum": ["full-time", "part-time", "internship", "contract"] },
                                    "job_url":       { "type": "string",  "nullable": true },
                                    "notes":         { "type": "string",  "nullable": true },
                                    "applied_date":  { "type": "string",  "format": "date", "nullable": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Application updated successfully" },
                    "404": { "description": "Application not found" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "delete": {
                "tags": ["Applications"],
                "summary": "Delete a job application",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "responses": {
                    "200": { "description": "Application deleted successfully" },
                    "404": { "description": "Application not found" },
                    "401": { "description": "Unauthenticated" }
                }
            }
        },
        "/api/covers": {
            "get": {
                "tags": ["Cover Letters"],
                "summary": "List all cover letters",
                "security": [{ "sanctum": [] }],
                "responses": {
                    "200": { "description": "Cover letters retrieved successfully" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "post": {
                "tags": ["Cover Letters"],
                "summary": "Create a new cover letter",
                "security": [{ "sanctum": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["title", "content"],
                                "properties": {
                                    "application_id": { "type": "integer", "nullable": true },
                                    "title":          { "type": "string",  "example": "Cover letter for Acme Corp" },
                                    "content":        { "type": "string",  "example": "Dear Hiring Manager..." }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Cover letter created successfully" },
                    "401": { "description": "Unauthenticated" },
                    "422": { "description": "Validation error" }
                }
            }
        },
        "/api/covers/{id}": {
            "get": {
                "tags": ["Cover Letters"],
                "summary": "Get a specific cover letter",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "responses": {
                    "200": { "description": "Cover letter retrieved successfully" },
                    "404": { "description": "Cover letter not found" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "put": {
                "tags": ["Cover Letters"],
                "summary": "Update a cover letter",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["title", "content"],
                                "properties": {
                                    "application_id": { "type": "integer", "nullable": true },
                                    "title":          { "type": "string" },
                                    "content":        { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Cover letter updated successfully" },
                    "404": { "description": "Cover letter not found" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "delete": {
                "tags": ["Cover Letters"],
                "summary": "Delete a cover letter",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "responses": {
                    "200": { "description": "Cover letter deleted successfully" },
                    "404": { "description": "Cover letter not found" },
                    "401": { "description": "Unauthenticated" }
                }
            }
        },
        "/api/events": {
            "get": {
                "tags": ["Events"],
                "summary": "List all events",
                "security": [{ "sanctum": [] }],
                "responses": {
                    "200": { "description": "Events retrieved successfully" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "post": {
                "tags": ["Events"],
                "summary": "Create a new event",
                "security": [{ "sanctum": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["title", "event_type", "event_date", "is_all_day"],
                                "properties": {
                                    "application_id": { "type": "integer", "nullable": true },
                                    "title":          { "type": "string",  "example": "Technical interview" },
                                    "event_type":     { "type": "string",  "enum": ["interview", "reminder", "assessment", "call", "deadline"] },
                                    "description":    { "type": "string",  "nullable": true },
                                    "event_date":     { "type": "string",  "format": "date", "example": "2026-05-01" },
                                    "is_all_day":     { "type": "boolean", "example": false },
                                    "event_time":     { "type": "string",  "example": "14:00", "nullable": true, "description": "Required when is_all_day is false. Format: HH:MM" },
                                    "location":       { "type": "string",  "nullable": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Event created successfully" },
                    "401": { "description": "Unauthenticated" },
                    "422": { "description": "Validation error" }
                }
            }
        },
        "/api/events/{id}": {
            "get": {
                "tags": ["Events"],
                "summary": "Get a specific event",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "responses": {
                    "200": { "description": "Event retrieved successfully" },
                    "404": { "description": "Event not found" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "put": {
                "tags": ["Events"],
                "summary": "Update an event",
                "security": [{ "sanctum": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["title", "event_type", "event_date", "is_all_day"],
                                "properties": {
                                    "application_id": { "type": "integer", "nullable": true },
                                    "title":          { "type": "string" },
                                    "event_type":     { "type": "string", "enum": ["interview", "reminder", "assessment", "call", "deadline"] },
                                    "description":    { "type": "string", "nullable": true },
                                    "event_date":     { "type": "string", "format": "date" },
                                    "is_all_day":     { "type": "boolean" },
                                    "event_time":     { "type": "string", "nullable": true },
                                    "location":       { "type": "string", "nullable": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Event updated successfully" },
                    "404": { "description": "Event not found" },
                    "401": { "description": "Unauthenticated" }
                }
            },
            "delete": {
                "tags": ["Events"],
                "summary": "Delete an event",
                "security": [{ "sanctum": [] }],
